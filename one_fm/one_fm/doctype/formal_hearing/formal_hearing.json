   "label": "Reason for Absence",
   "options": "\nTo Pressurize the Company\nWork Issue",
   "reqd": 1
  },
  {
   "depends_on": "eval:doc.location_status == \"Inside Kuwait\"",
   "fieldname": "absence_reason_details",
   "fieldtype": "Small Text",
   "label": "Absence Reason Details"
  },
  {
   "depends_on": "eval:doc.location_status == \"Inside Kuwait\"",
   "fieldname": "evidence_attachment",
   "fieldtype": "Attach",
   "label": "Evidence Attachment"
  },
  {
   "fieldname": "decisions_based_on_formal_hearing_section",
   "fieldtype": "Section Break",
   "label": "Decisions Based on Formal Hearing"
  },
  {
   "depends_on": "eval:doc.workflow_state != \"Draft\"",
   "fieldname": "operation_managers_decision",
   "fieldtype": "Select",
   "label": "Operation Manager's Decision",
   "mandatory_depends_on": "eval:doc.workflow_state == \"Pending Operation Manager\"",
