  "document_type": "Request for Material",
  "due_date_based_on": "schedule_date",
  "priority": 1,
  "disabled": 0,
  "description": "<p>Here is to inform you that the following {{ doctype }}({{ name }}) requires your attention/action.\n        <br>\n        The details of the request are as follows:\n        <br>\n        </p><table cellpadding=\"0\" cellspacing=\"0\" border=\"1\" style=\"border-collapse: collapse;\">\n            <thead>\n                <tr>\n                    <th style=\"padding: 10px; text-align: left; background-color: #f2f2f2;\">Label</th>\n                    <th style=\"padding: 10px; text-align: left; background-color: #f2f2f2;\">Value</th>\n                </tr>\n            </thead>\n        <tbody>\n        \n            <tr>\n                <td style=\"padding: 10px;\">Type</td>\n                <td style=\"padding: 10px;\">{{type}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Required Date</td>\n                <td style=\"padding: 10px;\">{{schedule_date}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Transaction Date</td>\n                <td style=\"padding: 10px;\">{{transaction_date}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Company</td>\n                <td style=\"padding: 10px;\">{{company}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Employee</td>\n                <td style=\"padding: 10px;\">{{employee}}</td>\n            </tr>\n            </tbody></table><p></p>",
  "is_assignment_rule_with_workflow": 1,
  "assign_condition": "workflow_state in ['Pending', 'Approved']",
  "close_condition": "workflow_state == 'RFP Processed'",
  "rule": "Based on Process Task",
