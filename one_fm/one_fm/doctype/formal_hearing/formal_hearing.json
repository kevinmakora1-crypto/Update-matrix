  },
  {
   "fieldname": "hr_managers_decision",
   "fieldtype": "Select",
   "label": "HR Manager's Decision",
   "options": "\nTerminate\nDo not Terminate"
  },
  {
   "depends_on": "eval:doc.workflow_state != \"Draft\"",
   "fieldname": "general_managers_decision",
   "fieldtype": "Select",
   "label": "General Manager's Decision",
   "mandatory_depends_on": "eval:doc.hr_managers_decision == \"Terminate\" && doc.workflow_state == \"Pending General Manager\"",
   "options": "\nTerminate\nDo not Terminate"
  },
  {
   "fieldname": "absence_case",
   "fieldtype": "Link",
   "label": "Absence Case",
   "options": "Absence Case"
