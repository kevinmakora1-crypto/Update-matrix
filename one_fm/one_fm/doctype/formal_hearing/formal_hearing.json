   "label": "Did not Attend First Hearing?"
  },
  {
   "default": "0",
   "depends_on": "eval:doc.did_not_attend_first_hearing == 1 && doc.location_status == \"Inside Kuwait\"",
   "fieldname": "did_not_attend_rescheduled_hearing",
   "fieldtype": "Check",
   "label": "Did not Attend Rescheduled Hearing?"
  },
  {
