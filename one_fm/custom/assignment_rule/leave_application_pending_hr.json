{
  "name": "Leave Application - Pending HR",
  "document_type": "Leave Application",
  "priority": 0,
  "disabled": 0,
  "description": "<p>Here is to inform you that the following {{ doctype }}({{ name }}) requires your attention/action.\n        <br>\n        The details of the request are as follows:\n        <br>\n        </p><table cellpadding=\"0\" cellspacing=\"0\" border=\"1\" style=\"border-collapse: collapse;\">\n            <thead>\n                <tr>\n                    <th style=\"padding: 10px; text-align: left; background-color: #f2f2f2;\">Label</th>\n                    <th style=\"padding: 10px; text-align: left; background-color: #f2f2f2;\">Value</th>\n                </tr>\n            </thead>\n        <tbody>\n        \n            <tr>\n                <td style=\"padding: 10px;\">Employee</td>\n                <td style=\"padding: 10px;\">{{employee}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Leave Type</td>\n                <td style=\"padding: 10px;\">{{leave_type}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Company</td>\n                <td style=\"padding: 10px;\">{{company}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">From Date</td>\n                <td style=\"padding: 10px;\">{{from_date}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">To Date</td>\n                <td style=\"padding: 10px;\">{{to_date}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Posting Date</td>\n                <td style=\"padding: 10px;\">{{posting_date}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Status</td>\n                <td style=\"padding: 10px;\">{{status}}</td>\n            </tr>\n            </tbody></table><p></p>",
  "is_assignment_rule_with_workflow": 1,
  "assign_condition": "workflow_state == \"Pending HR\"",
  "close_condition": "workflow_state == \"Approved\"",
  "rule": "Based on Field",
  "field": "custom_default_leave_application_operator",
  "doctype": "Assignment Rule",
