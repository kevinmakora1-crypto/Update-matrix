{
 "absolute_value": 0,
 "align_labels_right": 0,
 "creation": "2025-03-29 13:54:37.216425",
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "Purchase Order",
 "docstatus": 0,
 "doctype": "Print Format",
 "font": "Default",
 "font_size": 0,
 "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Purchase Order</title>\n    {% if doc.one_fm_request_for_purchase %}\n        {%- set rfm = frappe.db.get_value(\"Request for Purchase\",doc.one_fm_request_for_purchase,'request_for_material') -%}\n        {%- set rfm_site = frappe.db.get_value(\"Request for Material\",rfm,'site') -%}\n        {%- set rfm_owner = frappe.db.get_value(\"Request for Material\",rfm,'owner') -%}\n        \n    {% else %} \n        \n        {%- set rfm_site = \"\" -%}\n        {%- set rfm_owner = \"\" -%}\n    {% endif %}\n    {% if doc.contact_person %}\n        {%- set contact_email = frappe.db.get_value(\"Contact\",doc.contact_person ,'email_id') -%}\n        {%- set contact_phone = frappe.db.get_value(\"Contact\",doc.contact_person ,'phone') -%}\n        \n    {% else %} \n\n        {%- set contact_email = \"\" -%}\n        {%- set contact_phone = \"\" -%}\n\n    {% endif %}\n    <style>\n        #Item_table {\n        \n        border-collapse: collapse;\n        }\n    \n        #Item_table th, #Item_table td {\n            padding: 8px;\n            text-align: left;\n            border: 1px solid black; /* Keeps table structured */\n        }\n        #Item_table th:nth-child(1), #Item_table td:nth-child(1) { width: 5%; }   /* S. No */\n        #Item_table th:nth-child(2), #Item_table td:nth-child(2) { width: 10%; }  /* CODE */\n        #Item_table th:nth-child(3), #Item_table td:nth-child(3) { width: 50%; }  /* DESCRIPTION */\n        #Item_table th:nth-child(4), #Item_table td:nth-child(4) { width: 8%; }   /* UoM */\n        #Item_table th:nth-child(5), #Item_table td:nth-child(5) { width: 7%; }   /* QTY */\n        #Item_table th:nth-child(6), #Item_table td:nth-child(6) { width: 5%; }   /* CUR. */\n        #Item_table th:nth-child(7), #Item_table td:nth-child(7) { width: 3%; }  /* UNIT PRICE */\n        #Item_table th:nth-child(8), #Item_table td:nth-child(8) { width: 10%; }  /* TOTAL AMOUNT */\n            \n        table {\n             width: 100%;\n        }\n        .notes-row {\n            height: 80px; /* Space for notes */\n        }\n        .terms {\n            font-weight: bold;\n            text-align: center;\n        }\n        .terms-content {\n            padding: 10px;\n        }\n          table, th, td {\n            border: 1px solid black;\n            font-size: 90%;\n          }\n          .page-break {\n             page-break-after:always; \n          }\n          \n          .header-row{\n              text-align:center;\n              vertical-align: middle;\n              height: 70px;\n          }\n          .section-header {\n              text-align:center;\n              vertical-align: middle;\n          }\n          \n          .left-align {\n            text-align: left;\n            font-weight: bold;\n        }\n        .summary {\n            font-weight: bold;\n            background-color: #D3D3D3;\n        }\n        .header {\n            background-color: #D3D3D3;\n            text-align:center;\n            vertical-align: middle;\n            font-weight: bold;\n        }\n        .sub-header{\n            background-color: #D3D3D3;\n        }\n        .no-border {\n            border: none;\n        }\n        #po_header{\n            background-color: grey;\n            color:white;\n        }\n        .notes-header {\n            background-color: #d3d3d3;\n            font-weight: bold;\n            text-align: center;\n            vertical-align: middle;\n            height: 20px; /* Adjust height if needed */\n        }\n        \n    </style>\n    \n</head>\n<body>\n\n<table>\n    <tr>\n        <td rowspan=\"2\" style=\"width: 20%;\"><img src=\"/files/onefmlogo.png\"></td>\n        <td rowspan=\"2\" style=\"width: 40%;\">\n            <strong>ONE FACILITIES MANAGEMENT Co.</strong><br>\n            <strong>HUMOUD TOWER - FLOOR 9</strong><br>\n            <strong>QIBLA - FAHAD AL SALEM ST.</strong><br>\n            <strong>Tel. +965 1866336</strong>\n        </td>\n        <td class=\"header\" id = \"po_header\" colspan=\"3\">PURCHASE ORDER</td>\n    </tr>\n    <tr>\n        <td class=\"sub-header\"><b>PO#</b>: {{doc.name}}</td>\n        <td class=\"sub-header\"><b>DATE</b>: {{doc.transaction_date}}</td>\n    </tr>\n</table>\n<table>\n    <tr>\n        <td class=\"header\" colspan=\"2\">Supplier</td>\n        <td><strong>Payment Terms:</strong></td>\n        <td>{{doc.payment_terms_template or \"\"}}</td>\n    </tr>\n    <tr>\n        <td><strong>Name:</strong></td>\n        <td>{{doc.supplier}}</td>\n        <td><strong>RFQ Number: </strong></td>\n        <td>{{doc.custom_rfq_number or \"\"}}</td>\n    </tr>\n    <tr>\n        <td><strong>Address:</strong></td>\n        <td>{{doc.address_display or \"\"}}</td>\n        <td><strong>Project: </strong></td>\n        <td>{{doc.project or \"\"}}</td>\n    </tr>\n    <tr>\n        <td><strong>Contact No.</strong></td>\n        <td>{{contact_phone}}</td>\n        <td><strong>Site Code</strong></td>\n        <td>{{rfm_site or \"\"}}</td>\n    </tr>\n    <tr>\n        <td><strong>Email:</strong></td>\n        <td>{{contact_email or \"\"}}</td>\n        <td><strong>Supplier Code</strong></td>\n        <td>{{doc.supplier}}</td>\n    </tr>\n    \n</table>\n<table id=\"Item_table\">\n    <tr>\n        <th>S. No</th>\n        <th>CODE</th>\n        <th>DESCRIPTION</th>\n        <th>UoM</th>\n        <th>QTY</th>\n        <th>CUR.</th>\n        <th>UNIT PRICE</th>\n        <th>TOTAL AMOUNT</th>\n    </tr>\n    {%- for row in doc.items -%}\n        <tr>\n            <td>{{row.idx}}</td>\n            <td>{{row.item_code}}</td>\n            <td>{{row.item_name}} &nbsp; {{row.description}} </td>\n            <td>{{row.uom}}</td>\n            <td>{{row.qty}}</td>\n            <td>{{doc.currency}}</td>\n            <td>{{frappe.utils.fmt_money(row.rate)}}</td>\n            <td>{{frappe.utils.fmt_money(row.amount)}}</td>\n        </tr>\n    {% endfor %}\n    \n    <tr>\n        <td class=\"no-border\" colspan=\"8\"></td>\n    </tr>\n<tr>\n    <td rowspan=\"2\" colspan=\"2\">\n        <b>Kuwaiti Dinar <br> (In Words)</b>\n    </td>\n    <td rowspan=\"2\" colspan=\"3\" class=\"summary\" style=\"vertical-align: top; text-align: left;\">\n        <b>{{doc.in_words}}</b> \n    </td>\n    <td ><b>DISCOUNT</b></td>\n    <td class=\"summary\">KWD</td>\n    <td class=\"summary\">{{frappe.utils.fmt_money(doc.discount_amount)}}</td>\n</tr>\n<tr>\n    <td ><b>TOTAL AMOUNT</b></td>\n    <td class=\"summary\">KWD</td>\n    <td class=\"summary\">{{frappe.utils.fmt_money(doc.net_total)}}</td>\n</tr>\n</table>\n<table>\n    <tr>\n        <th>PURCHASE OFFICER</th>\n        <th>PROCUREMENT MANAGER</th>\n        <th>VENDOR ACCEPTANCE</th>\n    </tr>\n    <tr class=\"header-row\">\n        <td><strong>{{\"Approved\" if doc.custom_purchase_officer_approval_date else \"\"}}</strong></td>\n        <td><strong>{{\"Approved\" if doc.custom_purchase_manager_approval_date else \"\"}}</strong></td>\n        <td></td>\n    </tr>\n    <tr>\n        <th class=\"date-label\">DATE:&nbsp; &nbsp; {{doc.custom_purchase_officer_approval_date or \"\"}}</th>\n        <th class=\"date-label\">DATE:&nbsp; &nbsp; {{doc.custom_purchase_manager_approval_date or \"\"}}</th>\n        <th class=\"date-label\">DATE:</th>\n    </tr>\n</table>\n\n<table>\n    <tr>\n        <td colspan=\"2\" class=\"section-header\"><strong>DELIVERY</strong></td>\n    </tr>\n    <tr>\n        <th>DELIVERY DETAIL</th>\n        <th>DESCRIPTION</th>\n    </tr>\n    <tr>\n        <th>Delivery Location</th>\n        <td>{{doc.custom_place_of_delivery or \"\"}}</td>\n    </tr>\n    <tr>\n        <th>Delivery Contact</th>\n        <td>{{rfm_owner}}</td>\n    </tr>\n    <tr>\n        <th>Delivery Date</th>\n        <td>{{doc.schedule_date}}</td>\n    </tr>\n    <tr>\n        <th>Delivery Terms</th>\n        <td>\n            {{doc.terms or \"\"}}\n        </td>\n    </tr>\n    <tr>\n        <th>Packaging Type</th>\n        <td>{{doc.custom_packaging_type or \"\"}}</td>\n    </tr>\n</table>\n<table>\n    <tr text-align=\"center\">\n        <th colspan=\"2\" class = \"notes-header\" >{{ frappe.get_meta(\"Purchase Order\").get_field(\"other_conditions\").label }}</th>\n    </tr>\n    <tr class=\"notes-row\">\n        <td colspan=\"2\">{{doc.other_conditions or \"\"}}</td>\n    </tr>\n</table>\n\n<table>\n    <tr>\n        <th colspan=\"2\" class=\"terms\">TERMS & CONDITIONS</th>\n    </tr>\n    <tr>\n        <td class=\"terms-content\" colspan=\"2\">\n            <p>1: All goods must be delivered as per the specifications, quantity, and timeline mentioned in the Purchase Order. Any deviation must be communicated and approved in advance.</p>\n            <p>2: Failure to submit the invoice within the stipulated time may result in a delay in payment processing.</p>\n            <p>3: Both the invoice and the delivery note must clearly state the Purchase Order (PO) Number.</p>\n            <p>4: Payment will be processed as per the agreed terms upon receipt of all required documents and satisfactory delivery of goods.</p>\n        </td>\n    </tr>\n</table>\n</body>\n</html>",
