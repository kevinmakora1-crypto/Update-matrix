{
  "name": "Assign to Site Supervisor",
  "document_type": "Attendance Amendment",
  "priority": 0,
  "disabled": 0,
  "description": "<p>Here is to inform you that the following {{ doctype }}({{ name }}) requires your attention/action.\n        <br>\n        The details of the request are as follows:\n        <br>\n        </p><table cellpadding=\"0\" cellspacing=\"0\" border=\"1\" style=\"border-collapse: collapse;\">\n            <thead>\n                <tr>\n                    <th style=\"padding: 10px; text-align: left; background-color: #f2f2f2;\">Label</th>\n                    <th style=\"padding: 10px; text-align: left; background-color: #f2f2f2;\">Value</th>\n                </tr>\n            </thead>\n        <tbody>\n        \n            <tr>\n                <td style=\"padding: 10px;\">Project</td>\n                <td style=\"padding: 10px;\">{{project}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Site</td>\n                <td style=\"padding: 10px;\">{{site}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Year</td>\n                <td style=\"padding: 10px;\">{{year}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Month</td>\n                <td style=\"padding: 10px;\">{{month}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Attendance Record Based On</td>\n                <td style=\"padding: 10px;\">{{attendance_based_on}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Project Manager</td>\n                <td style=\"padding: 10px;\">{{project_manager}}</td>\n            </tr>\n            \n            <tr>\n                <td style=\"padding: 10px;\">Site Supervisor</td>\n                <td style=\"padding: 10px;\">{{site_supervisor}}</td>\n            </tr>\n            </tbody></table><p></p>",
  "is_assignment_rule_with_workflow": 1,
  "assign_condition": "doc.workflow_state == \"Draft\" and doc.prev_workflow_state == \"Pending Approval\"",
  "close_condition": "doc.workflow_state != \"Draft\"",
  "rule": "Based on Field",
  "doctype": "Assignment Rule",
